{
  "name": "@oscnord/get-video-resolution",
  "version": "1.0.0",
  "description": "Get the dimensions (width and height) of a video. Supports local files (MP4, WebM, MKV, AVI), HLS streams, and DASH manifests.",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscnord/get-video-resolution.git"
  },
  "author": "Oscar Nord",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/oscnord/get-video-resolution/issues"
  },
  "keywords": [
    "video",
    "resolution",
    "hls",
    "dash",
    "mp4",
    "webm",
    "mkv"
  ],
  "homepage": "https://github.com/oscnord/get-video-resolution#readme",
  "dependencies": {
    "@remotion/media-parser": "^4"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "typescript": "^5"
  }
}
